# .env.example を .env にコピーして値を設定してください

# Salesforce Connected App (OAuth)
SF_CLIENT_ID=your_consumer_key
SF_CLIENT_SECRET=your_consumer_secret
SF_DOMAIN=login
# Sandbox の場合: SF_DOMAIN=test
# n8n Connected App と同じ Callback URL を指定（完全一致が必要）
SF_REDIRECT_URI=https://your-n8n.example.com/rest/oauth2-credential/callback

# scripts/get_salesforce_token.py 実行後に設定
SF_REFRESH_TOKEN=
SF_INSTANCE_URL=

# Google Workspace (サービスアカウント)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_ADMIN_EMAIL=admin@your-domain.com
